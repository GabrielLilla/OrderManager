<Window x:Class="OrderManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Order Manager"
        Height="720" Width="980"
        MinHeight="600" MinWidth="850"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- Cores -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
        <SolidColorBrush x:Key="SuccessHoverBrush" Color="#15803D"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#B91C1C"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7C3AED"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#6D28D9"/>
        <SolidColorBrush x:Key="CardBrush" Color="White"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6B7280"/>

        <!-- Botão base com cantos arredondados e estados -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        </Style>
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- TextBox padrão -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox padrão -->
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Estilo de rótulo de campo -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <!-- Card -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="RowHeight" Value="34"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#1E3A8A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Cabeçalho -->
            <RowDefinition Height="Auto"/> <!-- Cliente -->
            <RowDefinition Height="Auto"/> <!-- Formulário de produto -->
            <RowDefinition Height="Auto"/> <!-- Botões de ação -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
            <RowDefinition Height="Auto"/> <!-- Rodapé -->
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="📦 Order Manager"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#111827"/>
            <TextBlock Text="Cadastre produtos físicos ou digitais, gerencie o pedido e notifique o cliente."
                       FontSize="13"
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Cliente -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="CLIENTE" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="CustomerNameBox"
                         Tag="Digite o nome do cliente..."/>
            </StackPanel>
        </Border>

        <!-- Formulário de produto -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="NOME DO PRODUTO" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="ProductNameBox"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="PREÇO BASE (R$)" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="PriceBox"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="TIPO DO PRODUTO" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="ProductTypeBox"
                              SelectionChanged="ProductTypeBox_SelectionChanged">
                        <ComboBoxItem Content="Físico" IsSelected="True"/>
                        <ComboBoxItem Content="Digital"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="6">
                    <TextBlock x:Name="ExtraLabelText"
                               Text="FRETE (R$)"
                               Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="ExtraBox"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Botões de ação -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="➕  Cadastrar Produto"
                    Style="{StaticResource PrimaryButton}"
                    Click="AddProduct_Click"/>
            <Button Content="🗑  Remover Selecionado"
                    Style="{StaticResource DangerButton}"
                    Click="RemoveProduct_Click"/>
            <Button Content="💰  Calcular Total"
                    Style="{StaticResource SuccessButton}"
                    Click="CalculateTotal_Click"/>
        </StackPanel>

        <!-- DataGrid -->
        <Border Grid.Row="4"
                Background="White"
                CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <DataGrid x:Name="ProductsGrid">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding Id}"
                                        Width="60"/>
                    <DataGridTextColumn Header="Tipo"
                                        Binding="{Binding TypeLabel}"
                                        Width="90"/>
                    <DataGridTextColumn Header="Nome"
                                        Binding="{Binding Name}"
                                        Width="*"/>
                    <DataGridTextColumn Header="Preço Base"
                                        Binding="{Binding Price, StringFormat=C}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Frete/Taxa"
                                        Binding="{Binding ExtraValue, StringFormat=C}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Total"
                                        Binding="{Binding FinalPrice, StringFormat=C}"
                                        Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#16A34A"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Rodapé: total + notificação + finalizar -->
        <Border Grid.Row="5" Style="{StaticResource Card}" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Total do pedido:"
                               FontSize="14"
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock x:Name="TotalText"
                               Text="R$ 0,00"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#16A34A"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Notificação:"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,0,8,0"/>
                    <ComboBox x:Name="NotificationTypeBox"
                              Width="120"
                              Margin="0,0,12,0"
                              SelectionChanged="NotificationTypeBox_SelectionChanged">
                        <ComboBoxItem Content="Email" IsSelected="True"/>
                        <ComboBoxItem Content="SMS"/>
                    </ComboBox>
                    <Button Content="✓  Finalizar Pedido"
                            Style="{StaticResource AccentButton}"
                            Click="FinalizeOrder_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
